{
  "name": "@sentiric/stream-sdk",
  "version": "0.3.9",
  "description": "Universal Sentiric Stream SDK. High-performance communication engine for Voice, Chat and AI interactions.",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/stream-sdk.umd.cjs",
  "module": "./dist/stream-sdk.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/stream-sdk.js",
      "require": "./dist/stream-sdk.umd.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly",
    "preview": "vite preview"
  },
  "author": "Sentiric Architecture Team",
  "license": "Apache-2.0",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "terser": "^5.27.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.2.3",
    "@sentiric/contracts": "git+https://github.com/sentiric/sentiric-contracts.git#v1.21.1",
    "protobufjs": "^8.0.0"
  }
}
